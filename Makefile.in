MKDIR_P = @MKDIR_P@
CP = @CP@
RM = @RM@

DISTDIR ?= dist

PROJECTS = windows10-gtk-theme \
           windows10-gtk-theme-dark \
           windows10-icon-theme

.PHONY : all $(PROJECTS) clean mostlyclean lint

all : $(PROJECTS)
	$(MKDIR_P) $(DISTDIR)
	for i in $(PROJECTS); do $(CP) $$i/*.deb $(DISTDIR); done

$(PROJECTS) :
	cd $@ && $(MAKE)

clean :
	for i in $(PROJECTS); do cd $$i && $(MAKE) $@ && cd ..; done
	$(RM) -r -f $(DISTDIR)

mostlyclean : clean
	for i in $(PROJECTS); do cd $$i && $(MAKE) $@ && cd ..; done
	$(RM) -f Makefile config.status config.log

lint : $(PROJECTS)
	for i in $(PROJECTS); do cd $$i && $(MAKE) $@ && cd ..; done

